# NuGet packages
packages/
*.nupkg

# Visual Studio
.vs/
*.user
*.suo
*.VC.db
*.VC.VC.opendb

# Build output
Debug/
Release/
x64/
Win32/
bin/
obj/

# Compiled files
*.obj
*.pdb
*.ilk
*.exe
*.dll
*.lib
*.exp

# Allow Wavefront OBJ model files inside game assets.
!assets/models/**/*.obj

# Logs
*.log

# Temporary files
*.tmp
*.bak

# OS files
Thumbs.db
.DS_Store

# Raw downloaded asset archives / temporary source files
assets/downloads/
assets/raw/

# Blender source files are large local scene-editor files.
assets/blender/*.blend
assets/blender/*.blend1
assets/blender/*.blend2
