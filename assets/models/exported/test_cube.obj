# Doorways test cube
# First OBJ model used to test the 3D asset pipeline.

v -0.5 -0.5 -0.5
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v  0.5 -0.5 -0.5

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0

vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# Front face, -Z
f 1/1/1 2/2/1 3/3/1 4/4/1

# Back face, +Z
f 5/1/2 6/4/2 7/3/2 8/2/2

# Left face, -X
f 5/1/3 8/2/3 2/3/3 1/4/3

# Right face, +X
f 4/1/4 3/2/4 7/3/4 6/4/4

# Top face, +Y
f 2/1/5 8/2/5 7/3/5 3/4/5

# Bottom face, -Y
f 5/1/6 1/2/6 4/3/6 6/4/6